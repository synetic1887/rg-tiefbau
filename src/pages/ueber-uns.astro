---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import Stats from "../components/Stats.astro";
import CtaBand from "../components/CtaBand.astro";
import BrandPanel from "../components/BrandPanel.astro";
import { company, advantages } from "../data/site";

const values = [
  { icon: "handshake", title: "Verlässlichkeit", text: "Ein Wort, ein Handschlag. Was wir zusagen, halten wir – termintreu und ohne Ausreden." },
  { icon: "shield", title: "Qualität", text: "Höchste Standards bei Material und Ausführung. Wir bauen, als wäre es unser eigenes Projekt." },
  { icon: "euro", title: "Transparenz", text: "Faire Preise und nachvollziehbare Kostenaufstellungen. Keine versteckten Posten." },
  { icon: "compass", title: "Flexibilität", text: "Hauptsitz in Butzbach, deutschlandweit einsatzbereit. Kurze Reaktionszeiten inklusive." },
];
---

<Layout
  title="Über uns – RG Hochbau & Tiefbau"
  description="RG Hochbau & Tiefbau aus Butzbach: ein neu gegründetes Unternehmen, geführt von einer Geschäftsführung mit über 35 Jahren Branchenerfahrung."
>
  <PageHero
    eyebrow="Über RG Hochbau & Tiefbau"
    title="Neu am Markt. Nicht neu im Geschäft."
    subtitle="Wir verbinden die Agilität eines jungen Unternehmens mit der Erfahrung einer Geschäftsführung, die seit über 35 Jahren auf dem Bau zu Hause ist."
    crumbs={[
      { label: "Start", href: "/" },
      { label: "Über uns", href: "/ueber-uns" },
    ]}
  />

  <!-- Story -->
  <section class="container-rg py-20 md:py-28">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div class="reveal relative">
        <BrandPanel
          variant="dark"
          ratio="aspect-[5/4]"
          label="RG Hochbau & Tiefbau"
          sublabel="Rudolf · Geis"
          pinIcon="building"
          class="shadow-[0_30px_60px_-35px_rgba(28,28,27,0.5)]"
        />
        <div class="absolute -right-4 -top-5 hidden rounded-2xl bg-white p-5 shadow-xl ring-1 ring-line sm:block">
          <p class="font-display text-sm font-700 text-graphite">Gegründet in</p>
          <p class="font-display text-3xl font-900 text-brand">{company.city}</p>
        </div>
      </div>

      <div class="reveal">
        <p class="eyebrow">Unsere Geschichte</p>
        <h2 class="section-title mt-4">Erfahrung, die man spürt.</h2>
        <p class="mt-5 text-lg leading-relaxed text-muted">
          RG Hochbau &amp; Tiefbau ist ein neu gegründetes Unternehmen mit Sitz in
          {company.city} im Herzen Hessens. Hinter dem Namen RG steht die Familie
          Rudolf · Geis – und eine Geschäftsführung, die über {company.experience} Jahre
          Erfahrung im Bauwesen mitbringt.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Diese Erfahrung ist unser Fundament. Wir wissen, worauf es auf der Baustelle
          ankommt: saubere Planung, ehrliche Kommunikation und ein Ergebnis, das hält.
          Vom kleinen Erdaushub bis zum kompletten Rohbau – wir packen an.
        </p>
        <div class="mt-8 flex items-center gap-4 rounded-2xl border border-line bg-sand p-5">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand text-white">
            <Icon name="check" class="h-6 w-6" />
          </span>
          <p class="font-600 text-anthracite">
            Geschäftsführer <span class="text-brand-dark">{company.managingDirector}</span> –
            Ihr direkter Ansprechpartner von der Anfrage bis zur Übergabe.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-cloud py-20 md:py-28">
    <div class="container-rg">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">Was uns ausmacht</p>
        <h2 class="section-title mt-4">Werte, auf die Sie bauen können</h2>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((v) => (
            <div class="reveal rounded-2xl bg-white p-7 text-center">
              <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-soft text-brand-dark">
                <Icon name={v.icon} class="h-7 w-7" stroke={1.5} />
              </span>
              <h3 class="mt-5 text-lg font-700">{v.title}</h3>
              <p class="mt-2.5 text-[0.96rem] leading-relaxed text-muted">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Stats />

  <!-- Advantages reuse -->
  <section class="container-rg py-20 md:py-28">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Ihre Vorteile</p>
      <h2 class="section-title mt-4">Darum RG Hochbau &amp; Tiefbau</h2>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        advantages.map((a) => (
          <div class="reveal flex gap-5 rounded-2xl border border-line bg-white p-7">
            <span class="font-mono text-3xl font-600 text-brand-tint">{a.no}</span>
            <div>
              <h3 class="text-lg font-700">{a.title}</h3>
              <p class="mt-2 text-[0.97rem] leading-relaxed text-muted">{a.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <div class="pb-20 md:pb-24">
    <CtaBand title="Lernen Sie uns kennen" />
  </div>
</Layout>
