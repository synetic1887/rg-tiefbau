---
import type { CollectionEntry } from "astro:content";
import Icon from "./Icon.astro";

interface Props {
  post: CollectionEntry<"news">;
  compact?: boolean;
}
const { post, compact = false } = Astro.props;
const d = post.data.date;
const formatted = d.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<a
  href={`/aktuelles/${post.slug}`}
  class:list={[
    "card group flex h-full flex-col overflow-hidden",
    compact ? "" : "",
  ]}
>
  <div class="relative overflow-hidden">
    <img
      src={post.data.cover}
      alt={post.data.coverAlt ?? post.data.title}
      loading="lazy"
      decoding="async"
      class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-xs font-700 uppercase tracking-wider text-brand-dark shadow backdrop-blur">
      {post.data.category}
    </span>
  </div>
  <div class="flex flex-1 flex-col gap-3 p-6">
    <p class="text-sm font-600 uppercase tracking-wider text-muted">{formatted}</p>
    <h3 class="text-xl font-800 leading-snug text-ink group-hover:text-brand-dark">
      {post.data.title}
    </h3>
    <p class="text-[0.97rem] leading-relaxed text-muted">{post.data.summary}</p>
    <span class="link-arrow mt-auto pt-2 text-[0.92rem]">
      Weiterlesen
      <Icon name="arrow-right" class="h-4 w-4" />
    </span>
  </div>
</a>
