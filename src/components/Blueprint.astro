---
// Technische Blueprint-Linienzeichnungen als dekorative Panel-Motive.
// Nutzung: <Blueprint name="hochbau" class="..." />
interface Props {
  name: "hochbau" | "tiefbau" | "site";
  class?: string;
}
const { name, class: className = "" } = Astro.props;

const motifs: Record<string, string> = {
  // Gebäude-Querschnitt mit Geschossen, Stützen, Fundament-Schraffur
  hochbau: `
    <path d="M14 250 H306" />
    <rect x="84" y="64" width="152" height="186" />
    <path class="hl" d="M74 64 H246" />
    <path d="M84 110 H236 M84 156 H236 M84 202 H236" />
    <path d="M135 64 V250 M185 64 V250" />
    <rect x="98" y="78" width="22" height="20" /><rect x="150" y="78" width="22" height="20" /><rect x="202" y="78" width="22" height="20" />
    <rect x="98" y="124" width="22" height="20" /><rect x="150" y="124" width="22" height="20" /><rect x="202" y="124" width="22" height="20" />
    <rect x="98" y="170" width="22" height="20" /><rect x="202" y="170" width="22" height="20" />
    <path d="M150 170 h22 v20 h-22 z" class="hl" />
    <path d="M84 250 l-8 8 M104 250 l-8 8 M124 250 l-8 8 M144 250 l-8 8 M164 250 l-8 8 M184 250 l-8 8 M204 250 l-8 8 M224 250 l-8 8" />
    <path d="M266 64 V250" /><path d="M261 64 H271 M261 250 H271" />
  `,
  // Tiefbau: Bodenschichten, Graben-Profil, verlegtes Rohr, Bemaßung
  tiefbau: `
    <path d="M10 96 H310" stroke-dasharray="2 7" />
    <path d="M10 130 H310" stroke-dasharray="2 7" />
    <path class="hl" d="M10 96 H104 L138 196 H208 L242 96 H310" />
    <circle cx="173" cy="168" r="22" />
    <circle cx="173" cy="168" r="12" />
    <path d="M138 192 H208" />
    <path d="M10 230 H310" stroke-dasharray="2 7" /><path d="M10 264 H310" stroke-dasharray="2 7" />
    <path d="M104 70 V96 M242 70 V96" />
    <path d="M104 80 H242" /><path d="M104 76 V84 M242 76 V84" />
    <path d="M150 80 l-10 -6 M150 80 l-10 6" /><path d="M196 80 l10 -6 M196 80 l10 6" />
  `,
  // Baustelle: Höhenlinien + Turmdrehkran als Linienzeichnung
  site: `
    <path d="M8 244 q150 -46 304 0" /><path d="M8 268 q150 -46 304 0" /><path d="M8 292 q150 -46 304 0" />
    <path d="M118 244 V92" /><path d="M104 244 H132" />
    <path class="hl" d="M118 100 H262" />
    <path d="M118 100 H72" />
    <path d="M118 92 L150 62 M118 92 L150 122 M150 62 L150 122" />
    <path d="M118 108 L256 108" stroke-dasharray="3 5" />
    <path d="M226 100 V150" /><circle cx="226" cy="158" r="7" />
    <path d="M86 100 L72 100 86 108 Z" />
  `,
};
const inner = motifs[name] ?? motifs.hochbau;
---
<svg
  viewBox="0 0 320 320"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={inner}
/>
<style>
  svg :global(.hl) {
    stroke: var(--color-brand);
    stroke-width: 2;
  }
</style>
