---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumbs?: { label: string; href: string }[];
}
const { eyebrow, title, subtitle, crumbs = [] } = Astro.props;
---
<section class="relative overflow-hidden border-b border-line bg-sand">
  <!-- subtle grid texture -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.5]"
    style="background-image:linear-gradient(to right,rgba(28,28,27,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(28,28,27,0.035) 1px,transparent 1px);background-size:48px 48px;"
  >
  </div>
  <div class="pointer-events-none absolute -right-20 top-1/2 h-72 w-72 -translate-y-1/2 rounded-full bg-brand/10 blur-3xl"></div>

  <div class="container-rg relative py-16 md:py-24">
    {
      crumbs.length > 0 && (
        <nav class="mb-5 flex items-center gap-2 text-sm text-muted" aria-label="Breadcrumb">
          {crumbs.map((c, i) => (
            <>
              {i > 0 && <span class="text-line">/</span>}
              <a href={c.href} class="transition-colors hover:text-brand-dark">{c.label}</a>
            </>
          ))}
        </nav>
      )
    }
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="mt-4 max-w-3xl text-[2.4rem] font-800 leading-[1.05] md:text-[3.6rem]">{title}</h1>
    {subtitle && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">{subtitle}</p>}
  </div>
</section>
